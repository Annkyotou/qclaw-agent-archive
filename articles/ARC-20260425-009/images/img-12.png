noteBackProfile":true,"cacheLimit":100001,"playLaunch":"enable","jsAssetsList":undefined,"scrollLaunchAppPercent":null,"xhsRealIp":"","userNotPreLoad":["6883c078000000001e0095de","678867e7000000000801f9fa","623c763b000000001000b5e7","621b5446000000001000f525","5f0a7dfb0000000001007eaa","5b17cb8bb1da146e8bb5941c"],"enableWriteShareCode":true},"visitMobileFromAndroidWxGuide":false,"androidWxWebId":"","shareContext":null,"supportWebp":false,"acceptLanguageFromHeader":undefined,"language":"*","cityPullConfig":null},"fakeModal":{"fakeModalVisible":false,"modalAppendParams":{"source":"","deeplink":""},"enableFakeModal":false,"launchSuccessCallback":undefined},"noteData":{"routeQuery":{"xsec_token":"ABSNPQQyZbYr5h8b98vXJXUGRM8h6APihO8ofFCus3aPg=","xsec_source":"pc_collect"},"data":{"noteData":{"atUserList":[],"time":1776293536000,"lastUpdateTime":1776293536000,"title":"LLM已经不性感了，越来越觉得LeCun 与李飞","desc":"不要总盯着文本模型，梳理一下世界模型的两种思路\nLLM在物理世界中受限，Yann LeCun提出JEPA架构，AI通过“心智模拟”理解现实。李飞飞的World Labs开发3D空间智能，AI将具备感知和操作能力。\n2026 年，开发者该往哪走？\n这是一场从“文本模型”到“物理 AI”的范式转移。\n• 对企业而言： 避开卷到极致的对话机器人，真正的蓝海在具身智能（Embodied AI）、工业孪生和机器人仿真。\n• 对开发者而言： 掌握 JEPA 风格的编码器和 3D 空间表征。LLM 将回归它作为“界面层”的本质，而基于空间智能的“世界模型”才是真正的核心。","interactInfo":{"shareCount":"652","followed":false,"sticky":false,"relation":"none","niceCount":"","collected":false,"commentCount":"152","collectedCount":"2,099","liked":false,"likedCount":"2,485"},"imageList":[{"height":2400,"width":1440,"url":"http:\u002F\u002Fsns-webpic-qc.xhscdn.com\u002F202605011859\u002F2ed83b92ae1399ed606f96f85150e45e\u002F1040g00831v0gbkgg3q005o2gef4g8a5lvm10i18!h5_1080jpg","traceId":"","infoList":[{"imageScene":"H5_DTL","url":"http:\u002F\u002Fsns-webpic-qc.xhscdn.com\u002F202605011859\u002F2ed83b92ae1399ed606f96f85150e45e\u002F1040g00831v0gbkgg3q005o2gef4g8a5lvm10i18!h5_1080jpg"},{"imageScene":"H5_PRV","url":"http:\u002F\u002Fsns-webpic-qc.xhscdn.com\u002F202605011859\u002F331bfacb036a45cc7e5736fc0f5b17df\u002F1040g00831v0gbkgg3q005o2gef4g8a5lvm10i18!style_d4c824